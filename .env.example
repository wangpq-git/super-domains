# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/domain_manage

# Redis
REDIS_URL=redis://redis:6379/0

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# App
APP_NAME=Domain Manage
ENV=production
DEBUG=false
AUTO_CREATE_TABLES=false

# Feishu approval workflow
FEISHU_APPROVAL_WEBHOOK_URL=
FEISHU_APPROVAL_BASE_URL=
FEISHU_APPROVAL_CALLBACK_TOKEN=
FEISHU_APPROVAL_ENCRYPT_KEY=
FEISHU_APPROVAL_SIGNATURE_TOLERANCE_SECONDS=300
# JSON map for Feishu identity -> local admin user
# Example: {"ou_xxx":"testadmin","testadmin@example.com":"testadmin"}
FEISHU_APPROVAL_ADMIN_MAP={}
