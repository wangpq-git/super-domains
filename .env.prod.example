# ============ 域名管理平台配置 ============

# --- 应用 ---
SECRET_KEY=<openssl rand -hex 32>
ENCRYPTION_KEY=<openssl rand -hex 32>
AUTO_CREATE_TABLES=false

# --- 数据库 ---
DB_PASSWORD=<openssl rand -hex 16>
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/domain_manage

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LDAP 认证 ---
LDAP_ENABLED=true
LDAP_HOST=ldap.adsconflux.xyz
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=ou=users,dc=adsconflux,dc=xyz
LDAP_BIND_DN=cn=read,dc=adsconflux,dc=xyz
LDAP_BIND_PASSWORD=<your_ldap_bind_password>
LDAP_USER_FILTER=(uid={username})

# --- 飞书审批 ---
# 群机器人 webhook，用于发送待审批卡片和结果通知
FEISHU_APPROVAL_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/<your_webhook_token>
# 后端对外可访问地址，用于卡片详情链接和审批接口回调定位
FEISHU_APPROVAL_BASE_URL=https://domain-manage.example.com
# 飞书事件订阅 token
FEISHU_APPROVAL_CALLBACK_TOKEN=<your_feishu_callback_token>
# 飞书事件订阅 encrypt key，用于签名校验
FEISHU_APPROVAL_ENCRYPT_KEY=<your_feishu_encrypt_key>
# 回调签名允许的时间偏差，单位秒
FEISHU_APPROVAL_SIGNATURE_TOLERANCE_SECONDS=300
# 飞书身份到本地管理员的映射，支持 open_id / user_id / email / username
FEISHU_APPROVAL_ADMIN_MAP={"ou_xxx":"testadmin","admin@example.com":"testadmin"}
