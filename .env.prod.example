# ============ 域名管理平台配置 ============

# --- 应用 ---
SECRET_KEY=<openssl rand -hex 32>
ENCRYPTION_KEY=<openssl rand -hex 32>

# --- 数据库 ---
DB_PASSWORD=<openssl rand -hex 16>
DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/domain_manage

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LDAP 认证 ---
LDAP_ENABLED=true
LDAP_HOST=ldap.adsconflux.xyz
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=ou=users,dc=adsconflux,dc=xyz
LDAP_BIND_DN=cn=read,dc=adsconflux,dc=xyz
LDAP_BIND_PASSWORD=<your_ldap_bind_password>
LDAP_USER_FILTER=(uid={username})
